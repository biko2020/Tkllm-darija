{
  "__comment": "Tkllm-darija — Infrastructure Dashboard",
  "id": null,
  "uid": "tkllm-infrastructure",
  "title": "Tkllm Infrastructure",
  "tags": ["tkllm", "infrastructure", "postgres", "redis", "kafka"],
  "timezone": "Africa/Casablanca",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "PostgreSQL — Active Connections",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "pg_stat_activity_count{state!=\"idle\"}",
          "legendFormat": "Active"
        },
        {
          "expr": "pg_stat_activity_count{state=\"idle\"}",
          "legendFormat": "Idle"
        },
        {
          "expr": "200",
          "legendFormat": "Max (200)"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 2,
      "title": "PostgreSQL — Transactions/s",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit{datname=\"tkllm_darija\"}[2m])",
          "legendFormat": "Commits/s"
        },
        {
          "expr": "rate(pg_stat_database_xact_rollback{datname=\"tkllm_darija\"}[2m])",
          "legendFormat": "Rollbacks/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 3,
      "title": "PostgreSQL — DB Size",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "pg_database_size_bytes{datname=\"tkllm_darija\"}",
          "legendFormat": "Database Size"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 4,
      "title": "Redis — Memory Usage",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "redis_memory_used_bytes",
          "legendFormat": "Used"
        },
        {
          "expr": "redis_memory_max_bytes",
          "legendFormat": "Max (512MB)"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 5,
      "title": "Redis — Commands/s by Type",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(redis_commands_total[2m])",
          "legendFormat": "Total Commands/s"
        },
        {
          "expr": "rate(redis_keyspace_hits_total[2m])",
          "legendFormat": "Cache Hits/s"
        },
        {
          "expr": "rate(redis_keyspace_misses_total[2m])",
          "legendFormat": "Cache Misses/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 6,
      "title": "Redis — Cache Hit Rate",
      "type": "gauge",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(redis_keyspace_hits_total[5m]) / (rate(redis_keyspace_hits_total[5m]) + rate(redis_keyspace_misses_total[5m])) * 100",
          "legendFormat": "Hit Rate %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "green", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Kafka — Consumer Group Lag",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "kafka_consumergroup_lag_sum",
          "legendFormat": "{{topic}} ({{consumergroup}})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "title": "Kafka — Messages In/Out per Topic",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(kafka_topic_partition_current_offset[2m])",
          "legendFormat": "{{topic}} produced"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "msgps" } }
    },
    {
      "id": 9,
      "title": "MinIO — Storage Usage",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "minio_cluster_capacity_usable_total_bytes - minio_cluster_capacity_usable_free_bytes",
          "legendFormat": "Used"
        },
        {
          "expr": "minio_cluster_capacity_usable_total_bytes",
          "legendFormat": "Total"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 10,
      "title": "MinIO — S3 Request Rate",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(minio_s3_requests_total[2m])",
          "legendFormat": "{{api_name}}"
        },
        {
          "expr": "rate(minio_s3_requests_errors_total[2m])",
          "legendFormat": "Errors"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    }
  ]
}