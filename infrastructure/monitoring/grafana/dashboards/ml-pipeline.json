{
  "__comment": "Tkllm-darija — ML Pipeline Dashboard",
  "id": null,
  "uid": "tkllm-ml-pipeline",
  "title": "Tkllm ML Pipeline",
  "tags": ["tkllm", "ml", "asr", "quality"],
  "timezone": "Africa/Casablanca",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Transcription Queue Depth",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "kafka_consumergroup_lag_sum{topic=\"transcription.requested\"}",
          "legendFormat": "Pending Transcriptions"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Transcription Rate",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(asr_transcriptions_total[5m])",
          "legendFormat": "Transcriptions/s"
        },
        {
          "expr": "rate(asr_transcriptions_failed_total[5m])",
          "legendFormat": "Failures/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 3,
      "title": "Transcription Success Rate",
      "type": "gauge",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "(1 - rate(asr_transcriptions_failed_total[1h]) / rate(asr_transcriptions_total[1h])) * 100",
          "legendFormat": "Success Rate %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 95 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "ASR Transcription Latency (P50 / P95 / P99)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(asr_transcription_duration_seconds_bucket[5m]))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(asr_transcription_duration_seconds_bucket[5m]))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(asr_transcription_duration_seconds_bucket[5m]))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 5,
      "title": "GPU Memory Usage",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "nvidia_gpu_memory_used_bytes",
          "legendFormat": "GPU {{gpu}} Used"
        },
        {
          "expr": "nvidia_gpu_memory_total_bytes",
          "legendFormat": "GPU {{gpu}} Total"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 6,
      "title": "Quality Review Queue",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "kafka_consumergroup_lag_sum{topic=\"quality.review.requested\"}",
          "legendFormat": "Pending Reviews"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Annotation Quality Score Distribution",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 16, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "avg_over_time(quality_annotation_score_avg[10m])",
          "legendFormat": "Avg Score"
        },
        {
          "expr": "0.75",
          "legendFormat": "Min Threshold (0.75)"
        },
        {
          "expr": "0.90",
          "legendFormat": "Auto-approve (0.90)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1
        }
      }
    },
    {
      "id": 8,
      "title": "Dataset Export Queue",
      "type": "stat",
      "gridPos": { "x": 16, "y": 16, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "kafka_consumergroup_lag_sum{topic=\"export.requested\"}",
          "legendFormat": "Pending Exports"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      }
    },
    {
      "id": 9,
      "title": "MLflow — Active Experiment Runs",
      "type": "stat",
      "gridPos": { "x": 0, "y": 24, "w": 8, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "mlflow_run_count{status=\"RUNNING\"}",
          "legendFormat": "Active Runs"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    }
  ]
}