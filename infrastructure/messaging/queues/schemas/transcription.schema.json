{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tkllm-darija.ma/schemas/messaging/transcription.schema.json",
  "title": "TranscriptionEvent",
  "description": "Used for both 'transcription.requested' and 'transcription.completed' Kafka topics. The 'eventType' discriminator selects the applicable sub-schema.",
  "oneOf": [
    { "$ref": "#/definitions/TranscriptionRequested" },
    { "$ref": "#/definitions/TranscriptionCompleted" }
  ],
  "definitions": {

    "TranscriptionRequested": {
      "title": "TranscriptionRequested",
      "type": "object",
      "required": ["eventId", "eventType", "version", "timestamp", "audioId", "contributorId", "storage"],
      "additionalProperties": false,
      "properties": {
        "eventId":       { "type": "string", "format": "uuid" },
        "eventType":     { "type": "string", "const": "transcription.requested" },
        "version":       { "type": "string", "enum": ["1.0"] },
        "timestamp":     { "type": "string", "format": "date-time" },
        "audioId":       { "type": "string", "format": "uuid" },
        "contributorId": { "type": "string", "format": "uuid" },
        "taskId":        { "type": "string", "format": "uuid" },
        "storage": {
          "type": "object",
          "required": ["bucket", "key"],
          "properties": {
            "bucket": { "type": "string" },
            "key":    { "type": "string" }
          }
        },
        "whisperConfig": {
          "type": "object",
          "description": "Optional per-job Whisper overrides (used for re-transcription with different settings).",
          "additionalProperties": false,
          "properties": {
            "model":        { "type": "string", "enum": ["tiny", "base", "small", "medium", "large-v3"] },
            "language":     { "type": "string", "description": "ISO 639-1 code or null for auto-detect." },
            "beamSize":     { "type": "integer", "minimum": 1, "maximum": 10 },
            "computeType":  { "type": "string", "enum": ["int8", "float16", "float32"] },
            "temperature":  { "type": "number", "minimum": 0, "maximum": 1 },
            "vad":          { "type": "boolean", "description": "Enable voice activity detection pre-filter." }
          }
        },
        "priority": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10,
          "default": 5,
          "description": "Job priority for BullMQ queue (10=highest). B2B-requested re-transcriptions get priority 8."
        },
        "retryCount": {
          "type": "integer",
          "minimum": 0,
          "default": 0,
          "description": "Number of previous failed attempts. Used to escalate to larger Whisper model."
        }
      }
    },

    "TranscriptionCompleted": {
      "title": "TranscriptionCompleted",
      "type": "object",
      "required": [
        "eventId", "eventType", "version", "timestamp",
        "audioId", "contributorId", "taskId",
        "status", "transcript"
      ],
      "additionalProperties": false,
      "properties": {
        "eventId":       { "type": "string", "format": "uuid" },
        "eventType":     { "type": "string", "const": "transcription.completed" },
        "version":       { "type": "string", "enum": ["1.0"] },
        "timestamp":     { "type": "string", "format": "date-time" },
        "audioId":       { "type": "string", "format": "uuid" },
        "contributorId": { "type": "string", "format": "uuid" },
        "taskId":        { "type": "string", "format": "uuid" },
        "status": {
          "type": "string",
          "enum": ["success", "failed", "partial"],
          "description": "Overall transcription outcome."
        },
        "transcript": {
          "type": "object",
          "required": ["text", "language", "confidence"],
          "additionalProperties": false,
          "properties": {
            "text": {
              "type": "string",
              "description": "Full transcript text in detected language."
            },
            "arabizi": {
              "type": "string",
              "description": "Transliterated Arabizi/Latin representation (if applicable)."
            },
            "language": {
              "type": "string",
              "description": "Detected language code (e.g. 'ar', 'fr', 'ar-MA')."
            },
            "confidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Overall Whisper confidence score."
            },
            "noSpeechProb": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Probability that the audio contains no speech."
            },
            "segments": {
              "type": "array",
              "description": "Word-level or segment-level timestamps.",
              "items": {
                "type": "object",
                "required": ["start", "end", "text"],
                "properties": {
                  "start":      { "type": "number", "description": "Segment start time in seconds." },
                  "end":        { "type": "number", "description": "Segment end time in seconds." },
                  "text":       { "type": "string" },
                  "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
                  "words": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "word":        { "type": "string" },
                        "start":       { "type": "number" },
                        "end":         { "type": "number" },
                        "probability": { "type": "number" }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "model": {
          "type": "object",
          "description": "Model configuration used for this transcription.",
          "properties": {
            "name":        { "type": "string", "description": "Whisper model name used." },
            "version":     { "type": "string" },
            "computeType": { "type": "string" },
            "device":      { "type": "string", "enum": ["cpu", "cuda", "mps"] }
          }
        },
        "processing": {
          "type": "object",
          "description": "Processing performance metadata.",
          "properties": {
            "durationSeconds":   { "type": "number", "description": "Wall-clock time taken for inference." },
            "rtf":               { "type": "number", "description": "Real-time factor (processing_time / audio_duration)." },
            "workerId":          { "type": "string", "description": "ID of the ASR worker pod that processed this job." },
            "gpuModel":          { "type": "string", "description": "GPU model used (e.g. 'Tesla T4')." }
          }
        },
        "error": {
          "type": "object",
          "description": "Present only when status is 'failed'.",
          "properties": {
            "code":    { "type": "string" },
            "message": { "type": "string" },
            "retryable": { "type": "boolean" }
          }
        }
      }
    }
  }
}