{
  "name": "@tkllm/ui",
  "version": "0.1.0",
  "private": true,
  "description": "Shared design system components — used by web-contributor and web-b2b",
  "main":  "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build":        "tsc",
    "dev":          "tsc --watch",
    "typecheck":    "tsc --noEmit",
    "lint":         "eslint \"src/**/*.{ts,tsx}\"",
    "format":       "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "clean":        "rimraf dist"
  },
  "peerDependencies": {
    "react":     "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx":                     "^2.1.1",
    "tailwind-merge":           "^2.6.0"
  },
  "devDependencies": {
    "@types/node":    "^22.10.7",
    "@types/react":   "^19.0.3",
    "typescript":     "^5.7.3",
    "tailwindcss":    "^3.4.17",
    "rimraf":         "^6.0.1"
  }
}