{
  "name": "@tkllm/validators",
  "version": "0.1.0",
  "private": true,
  "description": "Shared Zod validation schemas used by API, web apps, and services",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "zod": "^3.24.1",
    "class-validator": "^0.14.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "typescript": "^5.7.3",
    "rimraf": "^6.0.1"
  }
}
