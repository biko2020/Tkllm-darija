{
  "name": "@tkllm/types",
  "version": "0.1.0",
  "private": true,
  "description": "Shared TypeScript types & interfaces across all apps and services",
  "main":  "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build":        "tsc",
    "typecheck":    "tsc --noEmit",
    "lint":         "eslint \"src/**/*.ts\"",
    "format":       "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "clean":        "rimraf dist"
  },
  "devDependencies": {
    "@types/node":  "^22.10.7",
    "typescript":   "^5.7.3",
    "rimraf":       "^6.0.1"
  }
}