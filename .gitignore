#######################################
# ROOT & GENERAL
#######################################
.DS_Store
Thumbs.db
*.log
logs/

#######################################
# ENV FILES (CRITICAL)
#######################################
.env
.env.*
!.env.example

#######################################
# NODE / NEXT / TURBO
#######################################
node_modules/
.pnpm-store/
.next/
out/
dist/
build/
coverage/

#######################################
# TURBO
#######################################
.turbo/

#######################################
# FLUTTER (mobile app)
#######################################
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
build/
ios/Pods/
android/.gradle/
android/app/build/

#######################################
# PYTHON / ML
#######################################
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/

#######################################
# JUPYTER
#######################################
.ipynb_checkpoints/

#######################################
# ML MODELS (VERY IMPORTANT)
#######################################
*.pt
*.pth
*.h5
*.ckpt
*.onnx

#######################################
# DATA (DO NOT COMMIT RAW DATA)
#######################################
data/versions/*/raw/
data/versions/*/processed/
data/versions/*/intermediate/
data/versions/*/audio/

# Allow schemas + registry
!data/schemas/
!data/registry/
!data/samples/

#######################################
# AUDIO FILES
#######################################
*.wav
*.mp3
*.flac

#######################################
# DOCKER
#######################################
docker-compose.override.yml
*.env.docker

#######################################
# TERRAFORM
#######################################
.terraform/
*.tfstate
*.tfstate.backup

#######################################
# KUBERNETES
#######################################
*.secret.yaml

#######################################
# IDE
#######################################
.vscode/
.idea/

#######################################
# PRISMA
#######################################
prisma/dev.db

#######################################
# ML EXPERIMENTS
#######################################
ml/experiments/tracking/*
!ml/experiments/tracking/.gitkeep

#######################################
# FEATURE STORE CACHE
#######################################
ml/feature-store/**/cache/

#######################################
# TEMP FILES
#######################################
tmp/
temp/