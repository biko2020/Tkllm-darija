
# =============================================================================
# TKLLM-DARIJA — .gitignore
# =============================================================================

# ── Secrets & environment ────────────────────────────────────────────────────
.env
.env.local
.env.*.local
!.env.example

# ── Node / npm ───────────────────────────────────────────────────────────────
node_modules/
.npm/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
package-lock.json     # generated — not committed in monorepo
yarn.lock

# ── Turborepo ────────────────────────────────────────────────────────────────
.turbo/

# ── TypeScript ───────────────────────────────────────────────────────────────
*.tsbuildinfo
dist/
build/

# ── Next.js ──────────────────────────────────────────────────────────────────
.next/
out/

# ── NestJS ───────────────────────────────────────────────────────────────────
dist/

# ── Prisma ───────────────────────────────────────────────────────────────────
apps/api/node_modules/.prisma/

# ── Flutter / Dart ───────────────────────────────────────────────────────────
apps/mobile/.dart_tool/
apps/mobile/.flutter-plugins
apps/mobile/.flutter-plugins-dependencies
apps/mobile/build/
apps/mobile/.packages
apps/mobile/pubspec.lock   # keep for reproducible builds — remove if preferred

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# ── Jupyter ──────────────────────────────────────────────────────────────────
ml/notebooks/.ipynb_checkpoints/
*.ipynb_checkpoints

# ── ML / Model artefacts ─────────────────────────────────────────────────────
/tmp/hf_cache/
models/*.bin
models/*.pt
models/*.safetensors
*.ckpt
mlruns/              # local MLflow runs (use remote tracking URI)
wandb/

# ── DVC ──────────────────────────────────────────────────────────────────────
/data/versions/      # versioned dataset snapshots managed by DVC
!data/versions/.dvc/
/data/versions/.dvc/cache/

# ── Data ingestion ───────────────────────────────────────────────────────────
/data/ingestion/*.pyc
/data/ingestion/__pycache__/
/data/ingestion/config.yaml        # local configs, not committed
/data/samples/*.*                  # anonymized sample files (keep small test files if needed)
/data/schemas/*.json               # schema definitions (optional: commit if stable)
/data/registry/*.yaml              # dataset registry (commit if version-controlled)
/data/versions/                    # versioned dataset snapshots managed by DVC
!data/versions/.dvc/               # keep DVC pointers
/data/versions/.dvc/cache/


# ── Docker ───────────────────────────────────────────────────────────────────
infrastructure/docker/.env   # local override — root .env is the source of truth

# ── Test & Coverage ──────────────────────────────────────────────────────────
coverage/
*.lcov
test-results/
playwright-report/

# ── Editor / OS ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*.suo
*.user
*.log

# ── Certificates ─────────────────────────────────────────────────────────────
*.pem
*.key
*.crt
*.csr