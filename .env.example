# =============================================================================
# TKLLM-DARIJA — Environment Variables Example
# =============================================================================
# Copy this file to .env and fill in the required values before starting the services.
# ⚠️ NEVER commit real secrets or production values to version control.
# This file is meant to document all environment variables used by the project.
# =============================================================================

# -----------------------------------------------------------------------------
# GENERAL
# -----------------------------------------------------------------------------
NODE_ENV=development
APP_NAME=tkllm-darija
APP_VERSION=0.1.0
LOG_LEVEL=debug
TZ=Africa/Casablanca

# -----------------------------------------------------------------------------
# API SERVER
# -----------------------------------------------------------------------------
API_PORT=3000
API_HOST=0.0.0.0
API_PREFIX=api/v1
API_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:3000
GRAPHQL_PLAYGROUND=true
GRAPHQL_INTROSPECTION=true
GRAPHQL_DEBUG=true

# -----------------------------------------------------------------------------
# NEXT.JS PUBLIC (exposed to browser)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_APP_NAME=Tkllm-darija
NEXT_PUBLIC_APP_ENV=development

# -----------------------------------------------------------------------------
# AUTHENTICATION
# -----------------------------------------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ACCESS_TOKEN_EXPIRES_IN=15m
JWT_REFRESH_TOKEN_EXPIRES_IN=7d

# Supabase (use your own project or local Supabase)
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-supabase-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>
SUPABASE_JWT_SECRET=<your-supabase-jwt-secret>

NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-supabase-anon-key>

# Keycloak (optional - for B2B SSO)
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=tkllm-darija
KEYCLOAK_CLIENT_ID=tkllm-api
KEYCLOAK_CLIENT_SECRET=<your-keycloak-client-secret>

# OAuth2 (optional)
GOOGLE_CLIENT_ID=<your-google-oauth-client-id>
GOOGLE_CLIENT_SECRET=<your-google-oauth-client-secret>

# Phone / OTP (Twilio or alternative)
TWILIO_ACCOUNT_SID=<your-twilio-account-sid>
TWILIO_AUTH_TOKEN=<your-twilio-auth-token>
TWILIO_PHONE_NUMBER=<your-twilio-phone-number>

# -----------------------------------------------------------------------------
# DATABASE — PostgreSQL + TimescaleDB
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://tkllm_user:tkllm_password@localhost:5432/tkllm_darija
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=tkllm_darija
DATABASE_USER=tkllm_user
DATABASE_PASSWORD=tkllm_password
DATABASE_SSL=false
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# -----------------------------------------------------------------------------
# CACHE — Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL_DEFAULT=3600
REDIS_QUEUE_DB=1
REDIS_SESSION_DB=2
REDIS_CACHE_DB=3

# -----------------------------------------------------------------------------
# OBJECT STORAGE — MinIO (S3-compatible)
# -----------------------------------------------------------------------------
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=auto
S3_BUCKET=tkllm-audio
S3_BUCKET_AUDIO=tkllm-audio
S3_BUCKET_DATASETS=tkllm-datasets
S3_BUCKET_EXPORTS=tkllm-exports
S3_BUCKET_MODELS=tkllm-models
S3_PUBLIC_URL=http://localhost:9000/tkllm-audio

# -----------------------------------------------------------------------------
# ASYNC MESSAGING — Kafka
# -----------------------------------------------------------------------------
KAFKA_BROKER=localhost:9092
KAFKA_CLIENT_ID=tkllm-api
KAFKA_GROUP_ID=tkllm-consumer-group
KAFKA_SSL=false
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_TOPIC_AUDIO_UPLOADED=audio.uploaded
KAFKA_TOPIC_TRANSCRIPTION_REQUESTED=transcription.requested
KAFKA_TOPIC_TRANSCRIPTION_COMPLETED=transcription.completed
KAFKA_TOPIC_ANNOTATION_TASK_CREATED=annotation.task.created
KAFKA_TOPIC_QUALITY_REVIEW_REQUESTED=quality.review.requested
KAFKA_TOPIC_QUALITY_REVIEW_COMPLETED=quality.review.completed
KAFKA_TOPIC_REWARD_ISSUED=reward.issued
KAFKA_TOPIC_PAYMENT_PROCESSED=payment.processed
KAFKA_TOPIC_EXPORT_REQUESTED=export.requested

# -----------------------------------------------------------------------------
# ML / ASR WORKER
# -----------------------------------------------------------------------------
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_BEAM_SIZE=3
WHISPER_LANGUAGE=ar
HUGGINGFACE_TOKEN=<your-huggingface-token>
HUGGINGFACE_CACHE_DIR=/tmp/hf_cache
RUNPOD_API_KEY=<your-runpod-api-key>
RUNPOD_ENDPOINT_ID=<your-runpod-endpoint-id>
ASR_WORKER_CONCURRENCY=1
ASR_BATCH_SIZE=4
ASR_MAX_AUDIO_DURATION_SECONDS=300

# -----------------------------------------------------------------------------
# VECTOR STORE
# -----------------------------------------------------------------------------
VECTOR_STORE_PROVIDER=pinecone
PINECONE_API_KEY=<your-pinecone-api-key>
PINECONE_ENVIRONMENT=<your-pinecone-environment>
PINECONE_INDEX_NAME=tkllm-darija-embeddings
PINECONE_DIMENSION=1536
WEAVIATE_URL=http://localhost:8085
WEAVIATE_API_KEY=<your-weaviate-api-key>
WEAVIATE_CLASS_NAME=DarijaEmbedding

# -----------------------------------------------------------------------------
# ML EXPERIMENTATION
# -----------------------------------------------------------------------------
ML_EXPERIMENT_PROVIDER=mlflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=tkllm-darija-asr
MLFLOW_S3_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
WANDB_API_KEY=<your-wandb-api-key>
WANDB_PROJECT=tkllm-darija
WANDB_ENTITY=<your-wandb-entity>

# -----------------------------------------------------------------------------
# DATA PIPELINE
# -----------------------------------------------------------------------------
PIPELINE_ORCHESTRATOR=prefect
PREFECT_API_URL=http://localhost:4200/api
PREFECT_API_KEY=<your-prefect-api-key>
DAGSTER_HOME=/tmp/dagster_home
DAGSTER_POSTGRES_URL=postgresql://tkllm_user:tkllm_password@localhost:5432/tkllm_darija
DVC_REMOTE_URL=s3://tkllm-datasets/dvc
DVC_REMOTE_ACCESS_KEY_ID=minioadmin
DVC_REMOTE_SECRET_ACCESS_KEY=minioadmin
DVC_REMOTE_ENDPOINT_URL=http://localhost:9000

# -----------------------------------------------------------------------------
# QUALITY ENGINE
# -----------------------------------------------------------------------------
QUALITY_MIN_SCORE_THRESHOLD=0.75
QUALITY_HUMAN_REVIEW_THRESHOLD=0.60
QUALITY_AUTO_APPROVE_THRESHOLD=0.90
QUALITY_REVIEWERS_PER_TASK=3
QUALITY_INTER_ANNOTATOR_AGREEMENT=0.70

# -----------------------------------------------------------------------------
# ANALYTICS SERVICE
# -----------------------------------------------------------------------------
ANALYTICS_DB_URL=postgresql://tkllm_user:tkllm_password@localhost:5432/tkllm_darija
ANALYTICS_RETENTION_DAYS=365
ANALYTICS_AGGREGATION_INTERVAL=1h

# -----------------------------------------------------------------------------
# FINANCIAL / PAYMENT SERVICES (sandbox mode recommended for dev)
# -----------------------------------------------------------------------------
CMI_MERCHANT_ID=<your-cmi-merchant-id>
CMI_STORE_KEY=<your-cmi-store-key>
CMI_API_URL=https://testpayment.cmi.co.ma
CMI_CALLBACK_URL=http://localhost:3000/api/v1/payments/cmi/callback

ORANGE_MONEY_API_URL=https://api.orange.com/orange-money-webpay/mar/v1
ORANGE_MONEY_CLIENT_ID=<your-orange-money-client-id>
ORANGE_MONEY_CLIENT_SECRET=<your-orange-money-client-secret>
ORANGE_MONEY_MERCHANT_KEY=<your-orange-money-merchant-key>
ORANGE_MONEY_CALLBACK_URL=http://localhost:3000/api/v1/payments/orange/callback

INWI_MONEY_API_URL=<your-inwi-api-url>
INWI_MONEY_PARTNER_ID=<your-inwi-partner-id>
INWI_MONEY_API_KEY=<your-inwi-api-key>
INWI_MONEY_CALLBACK_URL=http://localhost:3000/api/v1/payments/inwi/callback

PAYPAL_CLIENT_ID=<your-paypal-client-id>
PAYPAL_CLIENT_SECRET=<your-paypal-client-secret>
PAYPAL_MODE=sandbox

WISE_API_KEY=<your-wise-api-key>
WISE_PROFILE_ID=<your-wise-profile-id>
WISE_ENV=sandbox

WALLET_MIN_PAYOUT_MAD=50
WALLET_MAX_PAYOUT_MAD=5000
WALLET_REWARD_PER_AUDIO_SECOND_MAD=0.10
FRAUD_MAX_SUBMISSIONS_PER_DAY=200
FRAUD_MAX_IDENTICAL_AUDIO_RATIO=0.05

# -----------------------------------------------------------------------------
# EMAIL
# -----------------------------------------------------------------------------
MAIL_PROVIDER=smtp
MAIL_FROM=no-reply@tkllm-darija.ma
MAIL_FROM_NAME=Tkllm-darija
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SENDGRID_API_KEY=<your-sendgrid-api-key>

# -----------------------------------------------------------------------------
# MONITORING
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_RELEASE=0.1.0
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
METRICS_PATH=/metrics
GRAFANA_URL=http://localhost:3001
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# -----------------------------------------------------------------------------
# RATE LIMITING & SECURITY
# -----------------------------------------------------------------------------
THROTTLE_TTL=60
THROTTLE_LIMIT=120
CORS_ORIGINS=http://localhost:3001,http://localhost:3002
COOKIE_SECRET=your-dev-cookie-secret-change-in-production
ENCRYPTION_KEY=your-32-byte-encryption-key-change-in-production

# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------
FEATURE_GAMIFICATION=true
FEATURE_AI_TUTOR=true
FEATURE_B2B_API_ACCESS=true
FEATURE_REALTIME_FEED=false
FEATURE_BENCHMARK_SUITE=false

# -----------------------------------------------------------------------------
# INFRASTRUCTURE / DOCKER COMPOSE
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=tkllm-darija
POSTGRES_USER=tkllm_user
POSTGRES_PASSWORD=tkllm_password
POSTGRES_DB=tkllm_darija
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_CONSOLE_PORT=9001
KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://localhost:9092
ZOOKEEPER_CLIENT_PORT=2181
MLFLOW_PORT=5000
PREFECT_PORT=4200